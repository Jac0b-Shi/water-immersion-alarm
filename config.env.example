# ========================================
# 浸水检测报警系统 - 配置文件示例
# ========================================
#
# 使用说明：
# 1. 复制此文件为 config.env
# 2. 根据实际情况修改下面的配置项
# 3. 运行 python generate_config.py 生成配置头文件
# 4. 重新编译项目
#
# 注意：config.env 包含敏感信息，已添加到 .gitignore

# ESP8266 支持已弃用，不再维护
WIFI_SSID=
WIFI_PASSWORD=

# 企业微信Webhook配置
# 获取方式：企业微信管理后台 -> 应用与小程序 -> 群机器人 -> 添加机器人
# 复制webhook地址中的key参数
WEBHOOK_KEY=你的webhook_key

# ========================================
# 通信模块功能开关 (1=启用, 0=禁用)
# ========================================
# ESP8266 WiFi模块（已弃用，不再维护，固定为0）
ENABLE_ESP8266=0

# 浸水传感器模块（ADC: PA0）
ENABLE_IMMERSION_SENSOR=1

# BC260 NB-IoT模块（通过USART2通信）
ENABLE_BC260=0

# 超声波液位模块（通过UART4通信，使用PC10/PC11，默认映射）
ENABLE_ULTRASONIC_SENSOR=0

# 有线网络模块（CH32V208内置10M以太网）
ENABLE_ETHERNET=0

# ========================================
# 以太网配置 (仅在ENABLE_ETHERNET=1时有效)
# ========================================
# 本机IP地址
ETH_IP_ADDR=192.168.1.10
# 网关地址
ETH_GATEWAY=192.168.1.1
# 子网掩码
ETH_NETMASK=255.255.255.0
# DNS服务器地址
ETH_DNS_SERVER=8.8.8.8

# ========================================
# HTTP代理服务器配置
# ========================================
#
# 说明：由于CH32V208和BC260都不支持SSL，需要HTTP代理转发HTTPS请求到企业微信
# 运行 tools/webhook_proxy.py 脚本作为代理服务器
#
# 注意：以太网（内网）和BC260（公网移动网络）可能需要不同的代理服务器，例如，在某些部署场景中：
# - 以太网只能访问内网，无法访问公网
# - BC260通过移动网络访问公网，无法访问内网

# 以太网代理服务器（部署在内网）
HTTP_PROXY_IP=192.168.1.1
HTTP_PROXY_PORT=8080

# BC260 NB-IoT代理服务器（部署在公网）
# 示例：部署在云服务器上的代理
BC260_PROXY_IP=0.0.0.0
BC260_PROXY_PORT=8080

# ========================================
# UDP 密钥验证配置（防止伪造消息）
# ========================================
# 设置一个或多个密钥字符串，设备发送的数据包需要以其中一个密钥开头才会被处理
# 多密钥用逗号分隔，例如: "KEY1,KEY2,KEY3"
# 
# 固件发送的数据包格式: [IMEI]:[密钥] + 3字节HEX数据
# 例如: "869999051234567:MYKEY089209"
#
# 如果留空，则不进行密钥验证（不建议在生产环境使用）
UDP_SECRET_KEY=your_secret_key_here

# ========================================
# 超声波液位模块配置 (仅在ENABLE_ULTRASONIC_SENSOR=1时有效)
# ========================================
# L07A 通过 UART4 通信，使用 CH32V208WBU6 的 PC10/PC11 默认映射
# 固件接收端使用 DMA 固定读取4字节帧：[0xFF, Data_H, Data_L, SUM]
ULTRASONIC_UART_BAUDRATE=115200

# 传感器测距有效范围（mm）
# 特殊返回值：0xFFFE=同频干扰，0xFFFD=未检测到物体
ULTRASONIC_MIN_DISTANCE_MM=0
ULTRASONIC_MAX_DISTANCE_MM=3000

# 采样调度策略
# 下面这组参数用于“空闲 + 突发重试”读取：
# - 先空闲 8 秒
# - 然后进入 2 秒突发窗口
# - 窗口内每 200ms 触发一次测距，拿到首个有效值后立即结束本轮
# 如果想用均匀采样方式，可把 ULTRASONIC_SAMPLING_BURST_DURATION_SECONDS 设为 0
ULTRASONIC_SAMPLING_IDLE_SECONDS=8
ULTRASONIC_SAMPLING_BURST_DURATION_SECONDS=2
ULTRASONIC_SAMPLING_BURST_INTERVAL_MS=200

# 定时上报模式
ULTRASONIC_PERIODIC_REPORT_ENABLED=1
ULTRASONIC_PERIODIC_REPORT_INTERVAL_MIN=30

# 高液位加密上报模式
# 这里直接配置“测距值”门限；当测距值小于该值时，说明水位升高到警戒范围
ULTRASONIC_HIGH_LEVEL_REPORT_ENABLED=1
ULTRASONIC_HIGH_LEVEL_DISTANCE_THRESHOLD_MM=200
ULTRASONIC_HIGH_LEVEL_REPORT_INTERVAL_MIN=5

# 滤波窗口参数
# 例如：5分钟内取50次样本，去掉最低20%和最高20%，对中间样本求平均
ULTRASONIC_FILTER_WINDOW_SECONDS=300
ULTRASONIC_FILTER_SAMPLE_COUNT=50
ULTRASONIC_FILTER_TRIM_PERCENT=20

# ========================================
# 浸水传感器配置 (仅在ENABLE_IMMERSION_SENSOR=1时有效)
# ========================================
IMMERSION_WET_THRESHOLD_MV=1000
IMMERSION_DRY_THRESHOLD_MV=500
IMMERSION_WET_CONFIRM_COUNT=2
IMMERSION_DRY_CONFIRM_COUNT=5
